#!/usr/bin/env bash
# SessionStart hook for Focus plugin
# Injects skill content into agent context on session start

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read the SKILL.md content (body only, skip frontmatter)
skill_file="${PLUGIN_ROOT}/skills/focus/SKILL.md"
if [ ! -f "$skill_file" ]; then
  exit 0
fi

# Extract body after frontmatter (skip everything between first and second ---)
skill_content=$(awk 'BEGIN{f=0} /^---$/{f++; next} f>=2{print}' "$skill_file")

# Also check for active plan and memory in current directory
context_hint=""
if [ -f .focus/memory.md ]; then
  last_session=$(sed -n '/^## Last Session/,/^## /p' .focus/memory.md 2>/dev/null | head -10)
  context_hint="\\n\\n=== Session Memory ===\\n${last_session}"
fi
if [ -f .focus/plan.md ]; then
  plan_header=$(head -15 .focus/plan.md 2>/dev/null)
  context_hint="${context_hint}\\n\\n=== Active Plan ===\\n${plan_header}"
fi

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_escaped=$(escape_for_json "$skill_content")
context_escaped=$(escape_for_json "$context_hint")
session_context="You have Focus enabled.\\n\\n${skill_escaped}${context_escaped}"

# Output format depends on platform
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
